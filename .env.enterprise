# Enterprise Feature Configuration

# Enable/Disable Safety Features
ENABLE_GUARDRAILS=True
ENABLE_AUDIT_LOGGING=True
ENABLE_SECURITY_CHECKS=True

# Compliance Settings
PII_REDACTION_ENABLED=True
WORM_STORAGE_PATH=./audit_logs

# Safety Settings
DENIED_TOPICS=political_advice,medical_advice,competitor_mentions

# Financial Limits
MAX_TRANSACTION_LIMIT=2000.0

# Identity Propagation (Simulated)
# In production, these are extracted from JWT/Auth headers
DEFAULT_USER_ID=user_123
DEFAULT_USER_ROLE=admin


# =============================================================================
# ── Vector Memory Store (Long-Term Agent Recall) ─────────────────────────────
# =============================================================================

# Backend: in_memory | chromadb | pinecone | qdrant
#          | opensearch_aws | azure_ai_search | azure_cosmos
VECTOR_MEMORY_ENABLED=false
VECTOR_MEMORY_BACKEND=in_memory
VECTOR_MEMORY_EMBEDDING=bedrock
VECTOR_MEMORY_COLLECTION=a2a_memories
VECTOR_MEMORY_TOP_K=5
VECTOR_MEMORY_SCORE_THRESHOLD=0.3
VECTOR_MEMORY_MAX_ENTRIES=1000

# Bedrock embeddings (default for AWS deployments)
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v1

# -----------------------------------------------------------------------------
# AWS OpenSearch Service (pip install opensearch-py requests-aws4auth)
# Uses SigV4 auth via existing AWS credentials — no extra secrets needed.
# VECTOR_MEMORY_BACKEND=opensearch_aws
# OPENSEARCH_HOST=https://search-<name>-<id>.us-east-1.es.amazonaws.com
# OPENSEARCH_SERVICE=es
# OPENSEARCH_REGION=us-east-1
# OPENSEARCH_INDEX=a2a-memories
# OPENSEARCH_VECTOR_DIM=1536

# -----------------------------------------------------------------------------
# Azure AI Search (pip install azure-search-documents)
# VECTOR_MEMORY_BACKEND=azure_ai_search
# AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
# AZURE_SEARCH_API_KEY=<admin-key>          # omit for Managed Identity
# AZURE_SEARCH_INDEX=a2a-memories
# AZURE_SEARCH_VECTOR_DIM=1536

# -----------------------------------------------------------------------------
# Azure Cosmos DB DiskANN (pip install azure-cosmos)
# Recommended for enterprise deployments: global distribution, low-latency,
# embeddings stored alongside session data for single-read retrieval.
# VECTOR_MEMORY_BACKEND=azure_cosmos
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=<primary-key>                  # omit for Managed Identity
# COSMOS_DATABASE=a2a_agent_memory
# COSMOS_CONTAINER=agent_memories
# COSMOS_VECTOR_DIM=1536
# COSMOS_VECTOR_POLICY=diskANN
