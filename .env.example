# =============================================================================
# A2A Multi-Agent System Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Bedrock Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: aws configure
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock LLM Model
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Core Service Ports
# -----------------------------------------------------------------------------
REGISTRY_PORT=8000
ORCHESTRATOR_PORT=8100
MCP_REGISTRY_PORT=8200
MCP_GATEWAY_PORT=8300

# -----------------------------------------------------------------------------
# Agent Ports
# -----------------------------------------------------------------------------
CODE_ANALYZER_PORT=8001
DATA_PROCESSOR_PORT=8002
RESEARCH_AGENT_PORT=8003
TASK_EXECUTOR_PORT=8004
OBSERVER_PORT=8005
MATH_AGENT_PORT=8006

# -----------------------------------------------------------------------------
# MCP Tool Ports
# -----------------------------------------------------------------------------
FILE_OPS_PORT=8210
DATABASE_PORT=8211
WEB_SEARCH_PORT=8212
CALCULATOR_PORT=8213

# -----------------------------------------------------------------------------
# Service Names
# -----------------------------------------------------------------------------
ORCHESTRATOR_NAME=MainOrchestrator
OBSERVER_NAME=SystemObserver
CODE_ANALYZER_NAME=CodeAnalyzer
DATA_PROCESSOR_NAME=DataProcessor
RESEARCH_AGENT_NAME=ResearchAgent
TASK_EXECUTOR_NAME=TaskExecutor
MATH_AGENT_NAME=MathAgent

# -----------------------------------------------------------------------------
# Workflow Configuration
# -----------------------------------------------------------------------------
# Enable workflow persistence (save to database)
ENABLE_PERSISTENCE=true

# Enable automatic retry with exponential backoff
ENABLE_RETRY=true
MAX_RETRIES=3
RETRY_DELAY=1.0
MAX_RETRY_DELAY=30.0

# Enable parallel execution of independent steps
ENABLE_PARALLEL=true
MAX_PARALLEL_STEPS=5

# Workflow timeout (seconds)
WORKFLOW_TIMEOUT=3600
STEP_TIMEOUT=300

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL=10
HEARTBEAT_TIMEOUT=60
MAX_QUEUE_SIZE=1000
MAX_CONCURRENT_TASKS=10

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
WORKFLOW_DB_PATH=./workflows.db
MCP_DATABASE_PATH=/tmp/mcp_database.db
MCP_WORKSPACE_PATH=/tmp/mcp_workspace

# -----------------------------------------------------------------------------
# Health Check Configuration
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=10
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=5

# -----------------------------------------------------------------------------
# WebSocket Configuration (Interactive Mode)
# -----------------------------------------------------------------------------
ENABLE_WEBSOCKET=true
WEBSOCKET_TIMEOUT=300
MAX_WEBSOCKET_CONNECTIONS=100

# =============================================================================
# Identity Provider Configuration (Enterprise Authentication)
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication Settings
# -----------------------------------------------------------------------------
# Enable/Disable Authentication (set to 'true' for production, 'false' for dev)
AUTH_ENABLED=false

# Identity Provider Type
# Options: azure_ad, okta, auth0, aws_cognito, keycloak, generic_oidc, none
AUTH_PROVIDER=none

# -----------------------------------------------------------------------------
# OIDC/OAuth Core Configuration
# -----------------------------------------------------------------------------
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# OIDC Discovery URL (auto-discovers endpoints from .well-known/openid-configuration)
# Leave endpoints blank if using discovery
AUTH_DISCOVERY_URL=

# Manual Endpoint Configuration (if not using discovery)
AUTH_JWKS_URI=
AUTH_TOKEN_ENDPOINT=
AUTH_AUTHORIZE_ENDPOINT=

# -----------------------------------------------------------------------------
# Token Validation Settings
# -----------------------------------------------------------------------------
AUTH_VALIDATE_SIGNATURE=true
AUTH_VALIDATE_EXPIRY=true
AUTH_ALGORITHMS=RS256

# Default Scopes (space-separated)
AUTH_DEFAULT_SCOPES=openid profile email

# Claims Configuration (customize based on your IdP)
AUTH_ROLE_CLAIM=roles
AUTH_TENANT_CLAIM=tenant_id

# =============================================================================
# Example Configurations for Popular IdPs
# =============================================================================

# --- Azure AD (Microsoft Entra ID) ---
# AUTH_ENABLED=true
# AUTH_PROVIDER=azure_ad
# AUTH_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# AUTH_AUDIENCE=api://{your-api-client-id}
# AUTH_CLIENT_ID={your-client-id}
# AUTH_CLIENT_SECRET={your-client-secret}
# AUTH_DISCOVERY_URL=https://login.microsoftonline.com/{tenant-id}/v2.0/.well-known/openid-configuration
# AUTH_TOKEN_ENDPOINT=https://login.microsoftonline.com/{tenant-id}/oauth2/v2.0/token
# AUTH_ROLE_CLAIM=roles

# --- Okta ---
# AUTH_ENABLED=true
# AUTH_PROVIDER=okta
# AUTH_ISSUER=https://{your-domain}.okta.com/oauth2/default
# AUTH_AUDIENCE=api://{your-api-identifier}
# AUTH_CLIENT_ID={your-client-id}
# AUTH_CLIENT_SECRET={your-client-secret}
# AUTH_DISCOVERY_URL=https://{your-domain}.okta.com/.well-known/openid-configuration
# AUTH_ROLE_CLAIM=groups

# --- Auth0 ---
# AUTH_ENABLED=true
# AUTH_PROVIDER=auth0
# AUTH_ISSUER=https://{your-domain}.auth0.com/
# AUTH_AUDIENCE={your-api-identifier}
# AUTH_CLIENT_ID={your-client-id}
# AUTH_CLIENT_SECRET={your-client-secret}
# AUTH_DISCOVERY_URL=https://{your-domain}.auth0.com/.well-known/openid-configuration

# --- AWS Cognito ---
# AUTH_ENABLED=true
# AUTH_PROVIDER=aws_cognito
# AUTH_ISSUER=https://cognito-idp.{region}.amazonaws.com/{user-pool-id}
# AUTH_AUDIENCE={your-app-client-id}
# AUTH_CLIENT_ID={your-app-client-id}
# AUTH_CLIENT_SECRET={your-app-client-secret}
# AUTH_DISCOVERY_URL=https://cognito-idp.{region}.amazonaws.com/{user-pool-id}/.well-known/openid-configuration

# --- Keycloak ---
# AUTH_ENABLED=true
# AUTH_PROVIDER=keycloak
# AUTH_ISSUER=https://{keycloak-server}/realms/{realm-name}
# AUTH_AUDIENCE=account
# AUTH_CLIENT_ID={your-client-id}
# AUTH_CLIENT_SECRET={your-client-secret}
# AUTH_DISCOVERY_URL=https://{keycloak-server}/realms/{realm-name}/.well-known/openid-configuration
# AUTH_ROLE_CLAIM=realm_access.roles

# -----------------------------------------------------------------------------
# On-Behalf-Of (OBO) Token Flow Configuration
# -----------------------------------------------------------------------------
# Used to exchange user tokens for tool-specific access tokens
# Scopes are defined per-tool in MCP server registration


# =============================================================================
# ── Vector Memory Store (Long-Term Agent Recall) ─────────────────────────────
# =============================================================================

# Enable / disable vector memory (default: false — zero overhead when off)
VECTOR_MEMORY_ENABLED=false

# Backend: in_memory | chromadb | pinecone | qdrant | weaviate | pgvector | redis
VECTOR_MEMORY_BACKEND=in_memory

# Embedding provider: bedrock | openai | sentence_transformers | none
# 'bedrock' reuses existing AWS credentials (recommended default)
VECTOR_MEMORY_EMBEDDING=bedrock

# Collection / index name used in the backend (shared across services)
VECTOR_MEMORY_COLLECTION=a2a_memories

# Number of memories to retrieve per query
VECTOR_MEMORY_TOP_K=5

# Minimum cosine similarity to include a memory (0.0–1.0)
VECTOR_MEMORY_SCORE_THRESHOLD=0.3

# Max entries kept in the in-memory store before oldest are evicted
VECTOR_MEMORY_MAX_ENTRIES=1000

# Optional: persist the in-memory store to disk across restarts
# VECTOR_MEMORY_PERSIST_PATH=./data/vector_memory.pkl

# -----------------------------------------------------------------------------
# Bedrock Embeddings (default — no extra dependencies)
# -----------------------------------------------------------------------------
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v1
# BEDROCK_REGION=us-east-1   # falls back to AWS_REGION

# -----------------------------------------------------------------------------
# OpenAI Embeddings  (pip install openai)
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_EMBEDDING=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Local / Offline Embeddings  (pip install sentence-transformers)
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_EMBEDDING=sentence_transformers
# ST_MODEL_NAME=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# ChromaDB Backend  (pip install chromadb)
# Local (persistent):   CHROMA_PERSIST_PATH set, no CHROMA_HOST needed
# Server mode:          set CHROMA_HOST + CHROMA_PORT
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_BACKEND=chromadb
# CHROMA_PERSIST_PATH=./data/chroma
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# -----------------------------------------------------------------------------
# Qdrant Backend  (pip install qdrant-client)
# Local:   QDRANT_HOST + QDRANT_PORT
# Cloud:   QDRANT_URL + QDRANT_API_KEY
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_BACKEND=qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# AWS OpenSearch Service (pip install opensearch-py requests-aws4auth)
# Native k-NN vector index on Amazon OpenSearch (managed Elasticsearch fork).
# SigV4 auth reuses existing AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / IAM Role.
# Note: S3 itself has no vector search capability — OpenSearch is the AWS-native
#       equivalent of a managed vector database.
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_BACKEND=opensearch_aws
# OPENSEARCH_HOST=https://search-<name>-<id>.us-east-1.es.amazonaws.com
# OPENSEARCH_SERVICE=es          # es (managed domain) | aoss (serverless)
# OPENSEARCH_REGION=us-east-1    # defaults to AWS_REGION
# OPENSEARCH_INDEX=a2a-memories
# OPENSEARCH_VECTOR_DIM=1536
# # Optional basic auth (skip if using SigV4 / IAM)
# # OPENSEARCH_USER=admin
# # OPENSEARCH_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Azure AI Search (pip install azure-search-documents)
# Fully managed HNSW vector index. Supports hybrid search (vector + BM25).
# Passwordless: omit AZURE_SEARCH_API_KEY; Managed Identity used automatically.
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_BACKEND=azure_ai_search
# AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
# AZURE_SEARCH_API_KEY=<admin-key-or-query-key>   # omit for Managed Identity
# AZURE_SEARCH_INDEX=a2a-memories
# AZURE_SEARCH_VECTOR_DIM=1536

# -----------------------------------------------------------------------------
# Azure Cosmos DB – DiskANN vector search (pip install azure-cosmos)
# Embeddings stored alongside item data in the same container.
# Partition key = /session_id for data locality and hot-partition avoidance.
# Passwordless: omit COSMOS_KEY; DefaultAzureCredential used automatically.
# Recommended for apps already using Cosmos DB for session/conversation state.
# -----------------------------------------------------------------------------
# VECTOR_MEMORY_BACKEND=azure_cosmos
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=<primary-or-secondary-key>   # omit for Managed Identity
# COSMOS_DATABASE=a2a_agent_memory
# COSMOS_CONTAINER=agent_memories
# COSMOS_VECTOR_DIM=1536
# COSMOS_VECTOR_POLICY=diskANN   # diskANN (scalable) | flat (small datasets)

# ^^ AWS and Azure cloud-native backends follow after the block above

