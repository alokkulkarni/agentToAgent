# Model Gateway — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── Service binding ─────────────────────────────────────────────────
MODEL_GATEWAY_HOST=0.0.0.0
MODEL_GATEWAY_PORT=8400
LOG_LEVEL=INFO

# ── Anthropic (direct API) ───────────────────────────────────────────
# Required for AnthropicProvider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── AWS / Bedrock ────────────────────────────────────────────────────
# Required for BedrockProvider; alternatively, mount ~/.aws via Docker volume
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
# Optional: cross-account role ARN for Bedrock
# AWS_BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockRole

# ── Google / Gemini ──────────────────────────────────────────────────
# Required for GeminiProvider
GOOGLE_API_KEY=your_google_api_key_here

# ── OpenAI ───────────────────────────────────────────────────────────
# Required for OpenAIProvider
OPENAI_API_KEY=your_openai_api_key_here
# Optional: custom base URL (Azure OpenAI or proxy)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com
# OPENAI_API_VERSION=2024-02-01

# ── Model selection defaults ─────────────────────────────────────────
# Default tier: economy | balanced | premium | reasoning
GATEWAY_DEFAULT_TIER=balanced
# Favour cheaper models when multiple are equally capable
GATEWAY_COST_OPTIMIZE=true
# Comma-separated list of preferred providers (tried first if healthy)
# e.g. GATEWAY_PREFERRED_PROVIDERS=anthropic,bedrock
GATEWAY_PREFERRED_PROVIDERS=

# ── Circuit breaker ──────────────────────────────────────────────────
# Consecutive failures before opening a circuit
GATEWAY_CB_FAILURE_THRESHOLD=3
# Seconds before attempting recovery from OPEN → HALF_OPEN
GATEWAY_CB_HALF_OPEN_AFTER_SEC=60
# Consecutive successes in HALF_OPEN to fully close
GATEWAY_CB_SUCCESS_THRESHOLD=2
# Maximum provider retry attempts per request
GATEWAY_MAX_RETRIES=2

# ── Health monitoring ────────────────────────────────────────────────
# Seconds between automatic health-check polls
GATEWAY_HEALTH_CHECK_INTERVAL_SEC=30

# ── Audit logging ────────────────────────────────────────────────────
# Directory where rotating JSONL audit logs are written
GATEWAY_AUDIT_LOG_DIR=./audit_logs
# Do NOT log raw message content in the audit trail (GDPR / compliance)
GATEWAY_AUDIT_REDACT_CONTENT=true
# Rotate audit log file at this size (bytes); default 50 MB
GATEWAY_AUDIT_MAX_FILE_BYTES=52428800
