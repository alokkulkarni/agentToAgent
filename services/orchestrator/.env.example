# =============================================================================
# Orchestrator Service — Runtime Configuration
# =============================================================================

ORCHESTRATOR_NAME=MainOrchestrator
ORCHESTRATOR_PORT=8100
REGISTRY_URL=http://registry:8000
MCP_GATEWAY_URL=http://mcp-gateway:8300
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# AWS Bedrock (REQUIRED)
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ----------------------------------------------------------------------------
# Workflow Features
# ----------------------------------------------------------------------------
ENABLE_PERSISTENCE=true
ENABLE_RETRY=true
MAX_RETRIES=3
ENABLE_PARALLEL=true
MAX_PARALLEL_STEPS=5
WORKFLOW_TIMEOUT=3600
STEP_TIMEOUT=300

# ----------------------------------------------------------------------------
# Shared Workflow Database
# WORKFLOW_DB_BACKEND=postgresql requires DATABASE_URL to be set
# ----------------------------------------------------------------------------
WORKFLOW_DB_BACKEND=sqlite
DATABASE_URL=
SQLITE_DB_PATH=/app/data/workflows.db

# ----------------------------------------------------------------------------
# HA / Multi-instance
# Set HA_BACKEND=redis to activate cross-instance shared state
# ----------------------------------------------------------------------------
HA_BACKEND=in_memory
REDIS_URL=redis://redis:6379
ORCHESTRATOR_INSTANCE_ID=
ORCHESTRATOR_PUBLIC_ENDPOINT=
OWNERSHIP_TTL=30

# ----------------------------------------------------------------------------
# Vector Memory Store (long-term agent recall)
# Qdrant runs as a sidecar container — see docker-compose.yml
# ----------------------------------------------------------------------------
VECTOR_MEMORY_ENABLED=true
VECTOR_MEMORY_BACKEND=qdrant
VECTOR_MEMORY_EMBEDDING=bedrock
VECTOR_MEMORY_COLLECTION=a2a_memories
VECTOR_MEMORY_TOP_K=5
VECTOR_MEMORY_SCORE_THRESHOLD=0.3
VECTOR_MEMORY_MAX_ENTRIES=1000
VECTOR_MEMORY_PERSIST_PATH=

# Bedrock embeddings (reuses AWS creds above)
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v1

# Qdrant (VECTOR_MEMORY_BACKEND=qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_URL=
